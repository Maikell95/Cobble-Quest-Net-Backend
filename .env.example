# ========================
# Cobble Quest Backend
# ========================

# Server
PORT=4000
NODE_ENV=development

# Frontend origin (CORS) — set to your Cloudflare Pages URL in production
# Supports comma-separated origins: https://tienda.wrquest.xyz,https://cobblequest.pages.dev
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayPal REST API
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Pelican Panel
PELICAN_URL=https://panel.wrquest.xyz
PELICAN_API_KEY=papp_your-application-api-key
PELICAN_CLIENT_API_KEY=pacc_your-client-api-key
PELICAN_SERVER_ID=your-game-server-id
PELICAN_LOBBY_SERVER_ID=your-lobby-server-id
PELICAN_VELOCITY_SERVER_ID=your-velocity-proxy-id

# Admin credentials (CHANGE IN PRODUCTION)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT Secret (GENERATE A STRONG RANDOM STRING FOR PRODUCTION)
JWT_SECRET=dev-secret-change-in-production
